# ── LLM Backend ──────────────────────────────────────────────────────────────
# Set to "ollama" for free local/cloud-routed models, or "anthropic" for Claude.
LLM_BACKEND=ollama

# ── Ollama settings (used when LLM_BACKEND=ollama) ───────────────────────────
# Any model you can run with: ollama run <model>
OLLAMA_MODEL=kimi-k2.6:cloud
OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic settings (used when LLM_BACKEND=anthropic) ─────────────────────
ANTHROPIC_API_KEY=your_key_here
LLM_MODEL=claude-3-haiku-20240307

# ── Embedding model (always via sentence-transformers, no API needed) ─────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
